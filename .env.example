# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# ID администратора (ваш Telegram ID)
ADMIN_IDS=123456789

# ID группового чата для уведомлений (опционально)
ALLOWED_CHAT_ID=-1001234567890

# Сроки действия (в днях)
VPN_EXPIRY_DAYS=30
PROXY_EXPIRY_DAYS=30

# Максимум бэкапов
MAX_BACKUPS=7

# Таймеры автоудаления (в секундах, 0 = не удалять)
DELETE_DELAY_TEMP=30
DELETE_DELAY_USER=120
DELETE_DELAY_PROXY_CARD=300
DELETE_DELAY_ADMIN=600
